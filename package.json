{
  "name": "short-rental-management",
  "version": "1.0.0",
  "description": "短租公寓房态管理系统",
  "main": "dist-electron/main.js",
  "author": "Rental Management System",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build && electron-builder",
    "build:vite": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "electron:dev": "vite",
    "electron:build": "vue-tsc --noEmit && vite build && electron-builder"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.1",
    "better-sqlite3": "^11.3.0",
    "dayjs": "^1.11.11",
    "element-plus": "^2.7.6",
    "pinia": "^2.1.7",
    "vue": "^3.4.29",
    "vue-router": "^4.3.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.2",
    "@vitejs/plugin-vue": "^5.0.5",
    "electron": "^31.0.2",
    "electron-builder": "^24.13.3",
    "sass": "^1.77.6",
    "typescript": "^5.4.5",
    "vite": "^5.3.1",
    "vite-plugin-electron": "^0.28.7",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vue-tsc": "^2.0.21"
  },
  "build": {
    "appId": "com.rental.management",
    "productName": "短租公寓房态管理系统",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist",
      "dist-electron"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
